{
  "name": "plugger-monorepo",
  "version": "0.2.1",
  "private": true,
  "description": "Plugger — a browser-native meta framework for building lazily-loaded plugins for any SPA.",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "build": "bun run --filter './packages/*' build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "bun run --filter '*' typecheck",
    "docs:dev": "bun run --filter @plugger/docs dev",
    "docs:build": "bun run --filter @plugger/docs build",
    "docs:preview": "bun run --filter @plugger/docs preview",
    "clean": "rm -rf packages/*/dist docs/dist examples/*/dist node_modules/.vite docs/node_modules/.vite examples/*/node_modules/.vite",
    "release": "bun run build && bun run test"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/preact": "^3.2.4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/vue": "^8.1.0",
    "@types/react": "^18.3.11",
    "@vitest/coverage-v8": "^2.1.4",
    "happy-dom": "^15.7.4",
    "preact": "^10.24.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4",
    "vue": "^3.5.12"
  },
  "workspaces": [
    "packages/*",
    "docs",
    "examples/*"
  ]
}
