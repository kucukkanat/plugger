{
  "name": "@plugger/core",
  "version": "0.2.1",
  "description": "Browser-native meta framework for building lazily-loaded plugins for any SPA.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "plugins",
    "plugin-system",
    "esm",
    "extensibility",
    "micro-frontends",
    "spa"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
